{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "manual_skill_semantic_patch.schema.json",
  "title": "ManualSkillSemanticPatch",
  "type": "object",
  "required": [
    "patch_id",
    "status",
    "denko_id",
    "name",
    "source_authority",
    "evidence",
    "problem_zh",
    "patch",
    "confidence",
    "needs_parser_rule",
    "reason_zh"
  ],
  "properties": {
    "patch_id": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["proposed", "accepted", "rejected", "superseded"]
    },
    "batch": { "type": ["string", "null"] },
    "denko_id": { "type": "string" },
    "name": { "type": "string" },
    "detail_url": { "type": ["string", "null"] },
    "source_authority": {
      "type": "string",
      "enum": ["detail_page", "manual_override", "screenshot_evidence"]
    },
    "evidence": {
      "type": "object",
      "required": ["field_path", "text_ja"],
      "properties": {
        "field_path": { "type": "string" },
        "component_id": { "type": ["string", "null"] },
        "level": { "type": ["string", "null"] },
        "table_index": { "type": ["integer", "null"] },
        "text_ja": { "type": "string" },
        "screenshot_path": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "problem_zh": { "type": "string" },
    "patch": {
      "type": "object",
      "required": ["operation", "field_path", "value"],
      "properties": {
        "operation": {
          "type": "string",
          "enum": ["set", "merge", "append", "replace_component", "add_component"]
        },
        "field_path": { "type": "string" },
        "value": {},
        "previous_value": {}
      },
      "additionalProperties": false
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "needs_parser_rule": { "type": "boolean" },
    "parser_rule_hint_zh": { "type": ["string", "null"] },
    "review_reasons": {
      "type": "array",
      "items": { "type": "string" }
    },
    "reason_zh": { "type": "string" },
    "created_by": { "type": ["string", "null"] },
    "created_at": { "type": ["string", "null"] }
  },
  "additionalProperties": false
}
