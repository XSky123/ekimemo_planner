{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "skill_fact.schema.json",
  "title": "SkillFact",
  "description": "Step1 ingestion fact record. Japanese source facts are preserved; English keys are used for structure.",
  "type": "object",
  "required": ["record_meta", "denko_id", "name", "pool", "skill_name", "detail_url"],
  "properties": {
    "record_meta": { "$ref": "record_meta.schema.json" },
    "denko_id": { "type": "string" },
    "name": { "type": "string" },
    "pool": { "type": "string", "enum": ["original", "extra", "special", "collab"] },
    "skill_name": { "type": ["string", "null"] },
    "detail_url": { "type": ["string", "null"] },
    "trigger_condition": {
      "type": ["string", "null"],
      "description": "Raw Japanese trigger condition, usually from 発動条件 or 発動条件・効果."
    },
    "effect_summary": {
      "type": ["string", "null"],
      "description": "Raw Japanese skill effect summary, usually from 効果 or 発動条件・効果."
    },
    "activation_type": {
      "type": ["string", "null"],
      "description": "Raw Japanese アクティベーションタイプ."
    },
    "skill_remarks": {
      "type": ["string", "null"],
      "description": "Raw Japanese 備考 from the skill condition/effect table."
    },
    "lv50": {
      "type": ["object", "null"],
      "properties": {
        "skill_level": { "type": ["string", "null"] },
        "special_explanation": { "type": ["string", "null"] },
        "effect": { "type": ["string", "null"] },
        "duration": { "type": ["string", "null"] },
        "cooldown": { "type": ["string", "null"] },
        "probability": { "type": "object" },
        "raw_row": { "type": "object" }
      }
    },
    "key_level_stats": {
      "type": "object",
      "description": "AP/HP/Exp rows at key levels 15, 30, 50, 60, 70, and 80 when present.",
      "patternProperties": {
        "^(15|30|50|60|70|80)$": {
          "type": "object",
          "properties": {
            "AP": { "type": ["string", "null"] },
            "HP": { "type": ["string", "null"] },
            "Exp": { "type": ["string", "null"] },
            "source_table_index": { "type": ["string", "null"] }
          }
        }
      }
    },
    "source_tables": { "type": ["object", "null"] },
    "skill_table_candidates": { "type": "array" },
    "note_zh": { "type": ["string", "null"] }
  }
}
