{"detail_page_probe": {"colspan_count": 6, "detail_hash": "6dc77b8a7f2d2d07f59c411df96e65359284a1e58251b7c203563ad7e8635088", "detail_title": "サブリナ・サンタバーバラ", "headings": [{"tag": "h1", "text": "サブリナ・サンタバーバラ"}, {"tag": "h2", "text": "プロフィール"}, {"tag": "h2", "text": "セリフ"}, {"tag": "h2", "text": "スキル"}, {"tag": "h2", "text": "ステータス詳細"}, {"tag": "h2", "text": "ラッピング"}, {"tag": "h2", "text": "名前について"}, {"tag": "h2", "text": "ステータスについて"}, {"tag": "h2", "text": "スキルについて"}, {"tag": "h2", "text": "その他"}, {"tag": "h2", "text": "コメント"}, {"tag": "h2", "text": "情報提供"}], "needs_table_matrix": true, "rowspan_count": 10, "skill_like_tables": [{"first_rows": [["発動条件・効果", "アクティベーションタイプ", "備考"], ["発動条件：編成内がすべてcool属性", "マスターにおまかせ", "効果時間の変更不可 このスキルは無効化されない"], ["先頭車両でんこの最大HP増加、増加分即時回復", "マスターにおまかせ", "効果時間の変更不可 このスキルは無効化されない"]], "row_count": 3, "table_index": 6}, {"first_rows": [["スキルLv", "コメント", "効果", "発動時間", "クールタイム"], ["Lv.1 (でんこLv. 5)", "一定時間、編成しているでんこがすべてcool属性のとき、先頭車両のでんこの最大HPが増加します。また、スキル効果開始時このスキルで増加した最大HP分、そのでんこのHPを回復します。なお、効果時間は変更できず、最大HPが増加する効果は無効化の対象になりません。成長するとサブリナのデンスタがより一層盛り上がり、効果量が増加し、効果時間が延長し、クールタイムが減少していきます。", "最大HP +6%", "30分", "2時間30分"], ["Lv.2 (でんこLv.15)", "一定時間、編成しているでんこがすべてcool属性のとき、先頭車両のでんこの最大HPが増加します。また、スキル効果開始時このスキルで増加した最大HP分、そのでんこのHPを回復します。なお、効果時間は変更できず、最大HPが増加する効果は無効化の対象になりません。海外では有名なデンスタグラマーのサブリナ。めぐるやみゅう、あこなども有名人として認識しているほど！リコも存在を知っているようですが、曰く、「媚が鼻についてむかつく」んだとか……？", "最大HP +7%", "35分", "2時間25分"]], "row_count": 9, "table_index": 8}, {"first_rows": [["第～弾", "ラッピング名", "効果", "効果", "効果"], ["第～弾", "ラッピング名", "ATK", "DEF", "スキル"], ["192", "スイートエンジェル'26", "+7%", "+1%", "効果+2.7%"]], "row_count": 4, "table_index": 11}], "source_url": "https://newekimemo.wiki.fc2.com/wiki/%E3%82%B5%E3%83%96%E3%83%AA%E3%83%8A%E3%83%BB%E3%82%B5%E3%83%B3%E3%82%BF%E3%83%90%E3%83%BC%E3%83%90%E3%83%A9", "table_count": 12}, "growth": {"is_vu_available": false, "level_cap": null, "mileage_final_ap": null, "mileage_final_hp": null, "vu_changes": []}, "identity": {"aliases": [], "attribute": "cool