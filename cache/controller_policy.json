{
  "schema_version": 1,
  "mode": "controller_first",
  "batch": {
    "default_size": 30,
    "min_size": 20,
    "max_size": 30,
    "reduce_to_min_when": [
      "new_template_family_detected",
      "low_confidence_rate_high",
      "same_review_reason_repeats"
    ]
  },
  "classification": {
    "parsed_ok": "Deterministic parser output is sufficient for the current stage.",
    "needs_parser_rule": "Repeated deterministic failure; try code/rule fix before LLM.",
    "needs_llm_snippet": "Only the smallest ambiguous source snippet needs semantic interpretation.",
    "needs_manual_review": "Conflict, screenshot-needed evidence, or high-impact uncertainty."
  },
  "llm_gate": {
    "allowed": [
      "minimal_ambiguous_japanese_snippet",
      "semantic_component_split_low_confidence",
      "unknown_template_after_table_matrix_parse",
      "source_conflict_explanation",
      "periodic_review_narrative_if_metrics_insufficient"
    ],
    "forbidden": [
      "whole_wiki_page",
      "whole_jsonl_file",
      "whole_database",
      "unchanged_hash_sufficient_confidence_record",
      "known_parser_failure_before_rule_attempt"
    ]
  },
  "review_report": {
    "format": "html",
    "directory": "data/reports",
    "required_metrics": [
      "batch_range",
      "record_count",
      "parse_success_rate",
      "review_reason_counts",
      "component_kind_counts",
      "unknown_template_count",
      "llm_snippet_count",
      "manual_review_count",
      "parser_auto_fix_candidates"
    ]
  }
}
